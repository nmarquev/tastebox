# Database
DATABASE_URL="file:./dev.db"

# OpenAI / OpenRouter API key
OPENAI_API_KEY="your-openai-api-key-here"

# Base URL del proveedor. Vacío = OpenAI. Para OpenRouter: https://openrouter.ai/api/v1
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"

# Modelo de texto (OpenRouter requiere prefijo de proveedor, ej: openai/gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# Modelo multimodal/visión para PDFs (opcional, default = OPENAI_MODEL)
# OPENAI_VISION_MODEL="gpt-4o-mini"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3003
NODE_ENV=development

# Upload settings
MAX_FILE_SIZE=10485760
